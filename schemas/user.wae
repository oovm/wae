model User {
    id: i64 = 0;
    @unique username: string;
    email: string;
    created_at: datetime = now();
    
    // 关系
    posts: Post[];
}

model Post {
    id: i64 = 0;
    title: string;
    content: string;
    author_id: i64;
    
    // 外键关联
    @belongs_to author: User;
    created_at: datetime = now();
}